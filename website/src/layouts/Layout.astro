---
import '../styles/global.css';
import { ui } from '../i18n/ui';
import type { Lang } from '../i18n/ui';

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
}

const { 
  lang = 'ko',
  title = lang === 'ko' ? "Watchtower - 로컬 개발 인프라 통합 플랫폼" : "Watchtower - Local Dev-Infra Control Center", 
  description = lang === 'ko' ? "도메인 헬스체크, MITM 프록시, API 모킹, 모바일 디버깅 및 터널링을 하나로 통합한 데스크톱 앱" : "Domain Health Check, Local MITM Proxy, API Mocking, and Mobile Tunneling in one place.",
} = Astro.props;

const t = (key: keyof typeof ui['ko'] | keyof typeof ui['en']) => {
  // @ts-ignore
  return ui[lang][key] ?? ui['ko'][key];
};

// Calculate alternative lang links based on current path
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const pathname = Astro.url.pathname;
const isChangelog = pathname.includes('changelog');
const koLink = isChangelog ? `${baseUrl}/ko/changelog` : `${baseUrl}/ko`;
const enLink = isChangelog ? `${baseUrl}/en/changelog` : `${baseUrl}/en`;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href={`${baseUrl}/favicon.svg`} />
  <meta name="viewport" content="width=device-width" />
  <meta name="generator" content={Astro.generator} />
  
  <!-- Primary Meta Tags -->
  <title>{title}</title>
  <meta name="title" content={title} />
  <meta name="description" content={description} />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="/favicon.svg" />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content="/favicon.svg" />
</head>
<body>
  <!-- Header -->
  <header>
    <div class="container nav-container">
      <a href={lang === 'ko' ? `${baseUrl}/ko` : `${baseUrl}/en`} class="logo" id="header-logo-link">
        <img src={`${baseUrl}/logo-text.svg`} alt="Watchtower" style="height: 18px; width: auto;" />
      </a>
      
      <nav class="nav-links">
        <a href={lang === 'ko' ? `${baseUrl}/ko` : `${baseUrl}/en`} class="nav-link" id="nav-home-link">{t('nav.home')}</a>
        <a href={lang === 'ko' ? `${baseUrl}/ko/changelog` : `${baseUrl}/en/changelog`} class="nav-link" id="nav-changelog-link">{t('nav.changelog')}</a>
        
        <!-- Language Switcher -->
        <div class="lang-switcher" style="display: flex; gap: 8px; font-size: 0.85rem; font-family: var(--font-display); font-weight: 600; border-left: 1px solid var(--border-color); padding-left: 15px; margin-left: 5px;">
          <a href={koLink} class={`lang-btn ${lang === 'ko' ? 'active' : ''}`} style={lang === 'ko' ? 'color: var(--color-primary);' : 'color: var(--color-text-muted);'}>KO</a>
          <span style="color: var(--border-color);">|</span>
          <a href={enLink} class={`lang-btn ${lang === 'en' ? 'active' : ''}`} style={lang === 'en' ? 'color: var(--color-primary);' : 'color: var(--color-text-muted);'}>EN</a>
        </div>

        <a href="https://github.com/GrangbelrLurain/watchtower" target="_blank" rel="noopener noreferrer" class="nav-git-btn" id="nav-github-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
            <path d="M9 18c-4.51 2-5-2-7-2" />
          </svg>
          GitHub
        </a>
      </nav>
    </div>
  </header>

  <!-- Slot for Page Content -->
  <slot />

  <!-- Footer -->
  <footer style="margin-top: 100px; padding: 40px 0; border-top: 1px solid var(--border-color); background: var(--bg-secondary);">
    <div class="container" style="display: flex; flex-direction: column; align-items: center; gap: 20px; text-align: center;">
      <div style="display: flex; align-items: center; gap: 10px;">
        <img src={`${baseUrl}/logo-text.svg`} alt="Watchtower" style="height: 22px; width: auto;" />
      </div>
      <p style="font-size: 0.9rem; color: var(--color-text-secondary); max-width: 500px;">
        {t('footer.desc')}
      </p>
      <div style="display: flex; gap: 20px; font-size: 0.9rem; color: var(--color-text-muted);">
        <span>{t('footer.license')}</span>
        <span>•</span>
        <a href="https://github.com/GrangbelrLurain/watchtower/blob/main/LICENSE" target="_blank" rel="noopener noreferrer" style="hover: color: var(--color-text-secondary)">License</a>
      </div>
    </div>
  </footer>
</body>
</html>
