---
// Root page for redirection
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, ''); // Remove trailing slash
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href={`${baseUrl}/favicon.svg`} />
  <meta name="viewport" content="width=device-width" />
  <title>Watchtower</title>
  
  <script is:inline define:vars={{ baseUrl }}>
    // Detect browser language and redirect to /en or /ko
    try {
      const userLang = navigator.language || navigator.userLanguage;
      if (userLang && userLang.toLowerCase().startsWith('en')) {
        window.location.replace(baseUrl + '/en');
      } else {
        window.location.replace(baseUrl + '/ko');
      }
    } catch (e) {
      window.location.replace(baseUrl + '/ko');
    }
  </script>
  
  <!-- Fallback for browsers with JavaScript disabled -->
  <noscript>
    <meta http-equiv="refresh" content={`0;url=${baseUrl}/ko`} />
  </noscript>
</head>
<body style="background: #060814;">
</body>
</html>
