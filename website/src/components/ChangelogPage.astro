---
import Layout from '../layouts/Layout.astro';
import { Content } from '../../../CHANGELOG.md';
import { ui } from '../i18n/ui';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const t = (key: keyof typeof ui['ko'] | keyof typeof ui['en']) => {
  // @ts-ignore
  return ui[lang][key] ?? ui['ko'][key];
};
---

<Layout lang={lang} title={lang === 'ko' ? "Horizon Gateway - 변경 이력 (Changelog)" : "Horizon Gateway - Changelog"}>
  <main>
    <!-- Background Glow -->
    <div class="glow-backdrop" style="top: 100px; left: 50%; transform: translateX(-50%);"></div>

    <section class="changelog-section container">
      <div class="changelog-header">
        <h1 class="changelog-title"><span class="text-gradient">Changelog</span></h1>
        <p class="changelog-subtitle">{t('changelog.subtitle')}</p>
      </div>

      <div class="changelog-card glass-panel">
        <div class="markdown-body">
          <Content />
        </div>
      </div>
    </section>
  </main>
</Layout>

<style is:global>
  /* Scoped markdown body styling in global scope for the rendered markdown */
  .changelog-section {
    max-width: 800px !important;
    margin-bottom: 100px;
  }

  .changelog-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .changelog-title {
    font-size: 3rem;
    margin-bottom: 0.5rem;
  }

  .changelog-subtitle {
    color: var(--color-text-secondary);
    font-size: 1.1rem;
  }

  .changelog-card {
    padding: 3rem;
    box-shadow: 0 20px 40px -15px rgba(0,0,0,0.5);
  }

  @media (max-width: 768px) {
    .changelog-card {
      padding: 1.5rem;
    }
  }

  /* Markdown Elements Styling */
  .markdown-body {
    font-family: var(--font-sans);
    color: var(--color-text-primary);
    line-height: 1.7;
  }

  .markdown-body h1 {
    display: none; /* Hide root H1 since we render our own header */
  }

  .markdown-body h2 {
    font-size: 1.8rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border-color);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .markdown-body h3 {
    font-size: 1.3rem;
    margin-top: 1.8rem;
    margin-bottom: 0.75rem;
    color: var(--color-secondary);
  }

  .markdown-body p {
    margin-bottom: 1.2rem;
    color: var(--color-text-secondary);
  }

  .markdown-body ul, .markdown-body ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .markdown-body li {
    margin-bottom: 0.5rem;
    color: var(--color-text-secondary);
  }

  .markdown-body li strong {
    color: var(--color-text-primary);
  }

  .markdown-body a {
    color: var(--color-secondary);
    border-bottom: 1px dashed var(--color-secondary);
  }

  .markdown-body a:hover {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }

  .markdown-body code {
    font-family: var(--font-mono);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border-color);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-size: 0.85em;
    color: var(--color-accent);
  }

  .markdown-body pre {
    background: rgba(0, 0, 0, 0.4) !important;
    border: 1px solid var(--border-color);
    padding: 1.2rem;
    border-radius: 8px;
    margin-bottom: 1.5rem;
    overflow-x: auto;
  }

  .markdown-body pre code {
    background: transparent;
    border: none;
    padding: 0;
    font-size: 0.85rem;
    color: var(--color-text-primary);
  }

  .markdown-body hr {
    border: none;
    border-top: 1px solid var(--border-color);
    margin: 2.5rem 0;
  }

  .markdown-body blockquote {
    border-left: 4px solid var(--color-primary);
    padding: 0.5rem 0 0.5rem 1rem;
    margin-bottom: 1.5rem;
    background: rgba(168, 85, 247, 0.03);
    border-radius: 0 8px 8px 0;
  }

  .markdown-body blockquote p {
    margin-bottom: 0;
    font-style: italic;
  }
</style>
