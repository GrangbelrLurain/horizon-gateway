{
  "name": "watchtower",
  "private": true,
  "version": "2.4.2",
  "packageManager": "pnpm@10.26.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/ensure-injection.mjs && vite",
    "build": "tsc && vite build",
    "build:injection": "vite build --mode injection",
    "watch:injection": "vite build --watch --mode injection",
    "preview": "vite preview",
    "tauri": "node scripts/tauri-env.mjs",
    "format": "biome check --write",
    "format:f": "biome check --write --unsafe",
    "type-check": "tsc --noEmit",
    "clippy": "cd src-tauri && cargo clippy",
    "prepare": "husky",
    "version:patch": "node scripts/bump-version.mjs patch",
    "version:minor": "node scripts/bump-version.mjs minor",
    "version:major": "node scripts/bump-version.mjs major",
    "web:dev": "node scripts/sync-logos.mjs && pnpm --prefix website dev",
    "web:build": "node scripts/sync-logos.mjs && pnpm --prefix website build"
  },
  "dependencies": {
    "@babel/standalone": "^8.0.2",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-router": "^1.158.1",
    "@tanstack/react-virtual": "^3.13.18",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@xyflow/react": "^12.11.1",
    "crypto-js": "^4.2.0",
    "framer-motion": "^12.33.0",
    "html2canvas": "^1.4.1",
    "jotai": "^2.19.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.563.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@tanstack/react-router-devtools": "^1.158.1",
    "@tanstack/router-plugin": "^1.158.1",
    "@tauri-apps/cli": "^2",
    "@types/babel__standalone": "^7.1.9",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.2.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "clsx": "^2.1.1",
    "daisyui": "5.5.1-beta.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "typescript": "~5.8.3",
    "vite": "^7.3.1"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "biome check --write"
    ]
  }
}
