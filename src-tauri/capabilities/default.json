{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "updater:default",
    "process:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "http://127.0.0.1:*" },
        { "url": "https://127.0.0.1:*" },
        { "url": "http://localhost:*" },
        { "url": "https://localhost:*" }
      ]
    },
    "dialog:default",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    {
      "identifier": "fs:allow-font-read",
      "allow": [{ "path": "C:\\Windows\\Fonts\\*" }]
    },
    {
      "identifier": "fs:allow-desktop-write",
      "allow": [{ "path": "$DESKTOP/*" }]
    },
    {
      "identifier": "fs:allow-document-write",
      "allow": [{ "path": "$DOCUMENT/*" }]
    },
    {
      "identifier": "fs:allow-download-write",
      "allow": [{ "path": "$DOWNLOAD/*" }]
    },
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-close",
    "core:window:allow-set-fullscreen",
    "core:window:allow-toggle-maximize",
    "core:window:allow-is-maximized",
    "core:window:allow-is-fullscreen",
    "core:window:allow-start-dragging"
  ]
}
